<button class="copy-btn" onclick="copyTable()">📋 複製表格文字</button>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const rows = document.querySelectorAll('#main-table tbody tr');
  const countLabel = document.getElementById('count-label');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const f = btn.dataset.filter;
      let count = 0;
      rows.forEach(row => {
        let show = false;
        if (f === 'all') show = true;
        else if (f === 'da') show = row.dataset.loc === 'da';
        else if (f === 'hoi') show = row.dataset.loc === 'hoi';
        else if (f === 'michelin') show = row.dataset.michelin === '1';
        else show = row.dataset.cat === f;
        row.classList.toggle('hidden', !show);
        if (show) count++;
      });
      countLabel.textContent = `顯示 ${count} 筆`;
    });
  });

  function copyTable() {
    const visibleRows = [...rows].filter(r => !r.classList.contains('hidden'));
    let text = ['#\t餐廳名稱\t地區\t類別\t營業時間\t訂位\t備註'].join('') + '\n';
    visibleRows.forEach(r => {
      const cells = r.querySelectorAll('td');
      text += [...cells].map(c => c.innerText.replace(/\n/g, ' ').trim()).join('\t') + '\n';
    });
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.querySelector('.copy-btn');
      btn.textContent = '✅ 已複製！';
      setTimeout(() => btn.textContent = '📋 複製表格文字', 2000);
    });
  }
</script>


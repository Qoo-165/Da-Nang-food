<!DOCTYPE html>

<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>峴港 × 會安 美食攻略</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Noto+Sans+TC:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --da-nang: #c0392b;
    --hoi-an: #e67e22;
    --coffee: #6f4e37;
    --bread: #d4a017;
    --viet: #27ae60;
    --dessert: #8e44ad;
    --pizza: #2980b9;
    --buffet: #16a085;
    --bg: #fdf6ec;
    --card: #fff;
    --text: #2c2c2c;
    --muted: #777;
    --border: #e8ddd0;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
font-family: ‘Noto Sans TC’, sans-serif;
background: var(–bg);
color: var(–text);
min-height: 100vh;
}

header {
background: linear-gradient(135deg, #1a0a00 0%, #3d1a00 50%, #1a0a00 100%);
padding: 36px 24px 28px;
text-align: center;
position: relative;
overflow: hidden;
}
header::before {
content: ‘’;
position: absolute;
inset: 0;
background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,255,255,0.02) 20px, rgba(255,255,255,0.02) 40px);
}
header h1 {
font-family: ‘Playfair Display’, serif;
color: #f5c842;
font-size: clamp(22px, 5vw, 38px);
letter-spacing: 2px;
position: relative;
}
header p {
color: rgba(255,220,150,0.7);
font-size: 13px;
margin-top: 6px;
position: relative;
letter-spacing: 1px;
}

.controls {
display: flex;
flex-wrap: wrap;
gap: 8px;
padding: 16px 16px 8px;
justify-content: center;
background: #fff;
border-bottom: 1px solid var(–border);
position: sticky;
top: 0;
z-index: 10;
box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.filter-btn {
border: 1.5px solid var(–border);
background: #fff;
padding: 5px 14px;
border-radius: 20px;
font-size: 12px;
cursor: pointer;
font-family: ‘Noto Sans TC’, sans-serif;
color: var(–muted);
transition: all 0.2s;
white-space: nowrap;
}
.filter-btn:hover { border-color: #c0392b; color: #c0392b; }
.filter-btn.active { background: #c0392b; border-color: #c0392b; color: #fff; }
.filter-btn.loc-hoi { –a: var(–hoi-an); }
.filter-btn.loc-hoi.active { background: var(–hoi-an); border-color: var(–hoi-an); }
.filter-btn.loc-da.active { background: var(–da-nang); border-color: var(–da-nang); }

.table-wrap {
overflow-x: auto;
padding: 16px;
}

table {
width: 100%;
min-width: 700px;
border-collapse: separate;
border-spacing: 0;
background: #fff;
border-radius: 12px;
overflow: hidden;
box-shadow: 0 4px 20px rgba(0,0,0,0.07);
}

thead tr {
background: linear-gradient(90deg, #2c1500, #4a2000);
}
thead th {
color: #f5c842;
font-size: 12px;
font-weight: 500;
letter-spacing: 1px;
padding: 12px 14px;
text-align: left;
white-space: nowrap;
}

tbody tr {
border-bottom: 1px solid var(–border);
transition: background 0.15s;
}
tbody tr:hover { background: #fdf0e0; }
tbody tr:last-child { border-bottom: none; }
tbody tr.hidden { display: none; }

td {
padding: 11px 14px;
font-size: 13px;
vertical-align: middle;
line-height: 1.5;
}

.num {
color: var(–muted);
font-size: 11px;
width: 28px;
text-align: center;
}

.name-cell {
font-weight: 500;
min-width: 160px;
max-width: 220px;
}

.loc-badge {
display: inline-block;
padding: 2px 9px;
border-radius: 12px;
font-size: 11px;
font-weight: 500;
white-space: nowrap;
}
.loc-da { background: #fde8e6; color: var(–da-nang); }
.loc-hoi { background: #fef0e0; color: var(–hoi-an); }

.cat-badge {
display: inline-block;
padding: 2px 9px;
border-radius: 12px;
font-size: 11px;
white-space: nowrap;
}
.cat-bread { background: #fef9e7; color: #b7950b; border: 1px solid #f9e79f; }
.cat-viet { background: #eafaf1; color: #1e8449; border: 1px solid #a9dfbf; }
.cat-coffee { background: #f5eee6; color: var(–coffee); border: 1px solid #d5c2ae; }
.cat-dessert { background: #f5eef8; color: var(–dessert); border: 1px solid #d7bde2; }
.cat-pizza { background: #eaf4fd; color: var(–pizza); border: 1px solid #aed6f1; }
.cat-buffet { background: #e8f8f5; color: var(–buffet); border: 1px solid #a2d9ce; }
.cat-pho { background: #fef5e7; color: #ca6f1e; border: 1px solid #f8c471; }

.hours { font-size: 12px; color: #555; white-space: nowrap; }

.book-yes { color: #c0392b; font-weight: 500; font-size: 12px; }
.book-no { color: #27ae60; font-size: 12px; }
.book-rec { color: #e67e22; font-size: 12px; }
.book-na { color: #bbb; font-size: 12px; }

.note-cell { font-size: 12px; color: #555; max-width: 240px; line-height: 1.6; }

.star { color: #e74c3c; font-size: 11px; margin-left: 3px; }

.legend {
display: flex;
flex-wrap: wrap;
gap: 8px;
padding: 12px 16px;
font-size: 11px;
color: var(–muted);
justify-content: center;
}
.legend span { display: flex; align-items: center; gap: 4px; }

.copy-btn {
